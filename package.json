{
  "name": "cobalt",
  "version": "1.0.0",
  "private": true,
  "description": "Cobalt — PERN-stack project & task manager. Frontend + serverless API deployed on Vercel.",
  "scripts": {
    "build": "cd frontend && npm install --include=dev && npm run build",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "migrate": "cd backend && node src/utils/migrate-http.js",
    "seed": "cd backend && node src/utils/seed-http.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "winston": "^3.13.1"
  }
}
