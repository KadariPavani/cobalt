{
  "name": "cobalt-backend",
  "version": "1.0.0",
  "description": "Production-grade REST API for Cobalt — Project & Task OS.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node src/utils/migrate.js up",
    "migrate:down": "node src/utils/migrate.js down",
    "seed": "node src/utils/seed.js",
    "db:reset": "node src/utils/migrate.js down && node src/utils/migrate.js up && node src/utils/seed.js"
  },
  "keywords": ["express", "postgresql", "jwt", "rest-api"],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "winston": "^3.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
